---
const {
  title,
  isPost = false,
  frontmatter,
  description,
  canonicalURL,
  ogImage,
} = Astro.props;
const defaultDescription = "Technologist and Developer";
const pageTitle = title || frontmatter?.title;
const pageDescription =
  description || frontmatter?.description || defaultDescription;
import Footer from "../components/Footer.astro";
import WiggleWrap from "../components/WiggleWrap.astro";
import avatarImage from "../assets/avatar-pink-tv-ghibli-small.png";
import { ViewTransitions } from "astro:transitions";
const resolvedOgImage = ogImage ?? avatarImage.src;
---

<!doctype html>
<html
  lang="en"
  class="bg-no-repeat bg-cover bg-gradient-to-r from-indigo-950 to-emerald-950 text-violet-50 min-h-screen"
>
  <head>
    <!-- Basic Page Needs
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta charset="utf-8" />
    <title>Gil Creque - {pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Gil Creque" />

    <!-- Open Graph / Social Media
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={`Gil Creque - ${pageTitle}`} />
    <meta property="og:description" content={pageDescription} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`Gil Creque - ${pageTitle}`} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <link rel="canonical" href=`${canonicalURL}` />

    <!-- Google Site Verification
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta
      name="google-site-verification"
      content="baTB5HjY84P_avk0rfsFGUFu6_CqqmyNZUh13QCsLM8"
    />

    <!-- Mobile Specific Metas
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- FONT
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->

    <!-- CSS
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->

    <!-- Favicon
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <link
      rel="shortcut icon"
      type="image/x-icon"
      href="/img/avatar-pink-tv-ghibli-small.png"
      sizes="16x16"
    />
    <link
      rel="icon"
      type="image/x-icon"
      href="/img/avatar-pink-tv-ghibli-small.png"
      sizes="16x16"
    />
    <link
      rel="apple-touch-icon-precomposed"
      href="/img/avatar-pink-tv-ghibli-small.png"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed for gil.dev"
      href="/rss.xml"
    />
    <ViewTransitions />
  </head>
  <body class:list={["mx-auto", isPost ? "max-w-3xl" : "max-w-7xl"]}>
    <!-- Primary Page Layout
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->

    <header
      class:list={[
        "flex flex-col md:flex-row px-2 w-full items-center justify-center",
        isPost ? "max-w-3xl" : "max-w-7xl",
      ]}
    >
      <a href="/" class="hero-avatar-wrap mr-3 focus:outline-none">
        <div class="hero-ring hero-ring--hover"></div>
        <img
          id="avatar"
          transition:name="avatar"
          src={avatarImage.src}
          alt="Photo of Gil Creque in a pink TV"
          height="100px"
          width="100px"
          class="rounded-full"
          style="border: 2px solid var(--mint-green);"
        />
      </a>
      <h1 class="grow text-center">
        <img
          src="/img/microblog.svg"
          width="24px"
          height="24px"
          class="inline"
          alt="Micro.blog Icon"
        />{" "}
        <WiggleWrap>{pageTitle}</WiggleWrap>
      </h1>
    </header>
    <main class:list={["px-2 w-full", isPost ? "max-w-3xl" : "max-w-7xl"]}>
      <slot />
      <!-- your content is injected here -->
    </main>

    <Footer />
  </body><!-- End Document
    ––––––––––––––––––––––––––––––––––––––––––––––––––
-->
</html>
