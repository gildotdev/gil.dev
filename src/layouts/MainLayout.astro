---
const { title, isHome = false, frontmatter, description, ogImage } = Astro.props;
const defaultDescription = "Technologist and Developer";
const pageTitle = title || frontmatter?.title;
const pageDescription = description || frontmatter?.description || defaultDescription;
import Footer from "../components/Footer.astro";
import LatestNotes from "../components/LatestNotes.astro";
import WiggleWrap from "../components/WiggleWrap.astro";
import avatar from "../assets/avatar-pink-tv.jpeg";
import { ViewTransitions } from "astro:transitions";
import LatestPosts from "../components/LatestPosts.astro";
import KnowledgeGarden from "../components/KnowledgeGarden.astro";
import "../styles/global.css";
---

<!doctype html>
<html
  lang="en"
  class="bg-no-repeat bg-cover bg-gradient-to-r from-indigo-950 to-emerald-950 text-violet-50 min-h-screen"
>
  <head>
    <!-- Basic Page Needs
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta charset="utf-8" />
    <title>Gil Creque - {pageTitle}</title>
    <meta
      name="description"
      content={pageDescription}
    />
    <meta name="author" content="Gil Creque" />

    <!-- Open Graph / Social Media
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`Gil Creque - ${pageTitle}`} />
    <meta property="og:description" content={pageDescription} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={`Gil Creque - ${pageTitle}`} />
    <meta name="twitter:description" content={pageDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Google Site Verification
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta
      name="google-site-verification"
      content="baTB5HjY84P_avk0rfsFGUFu6_CqqmyNZUh13QCsLM8"
    />

    <!-- Mobile Specific Metas
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicon
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <link
      rel="shortcut icon"
      type="image/x-icon"
      href="/img/avatar-pink-tv.jpeg"
      sizes="16x16"
    />
    <link
      rel="icon"
      type="image/x-icon"
      href="/img/avatar-pink-tv.jpeg"
      sizes="16x16"
    />
    <link rel="apple-touch-icon-precomposed" href="/img/avatar-pink-tv.jpeg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed for gil.dev"
      href="/rss.xml"
    />
    <ViewTransitions />
  </head>
  <body class="max-w-3xl mx-auto">
    <!-- Primary Page Layout
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->

    <header
      class={`flex flex-row px-2 w-full max-w-3xl items-center gap-8${isHome ? " hero-header" : " justify-center"}`}
    >
      {
        isHome ? (
          <>
            <div class="hero-avatar-wrap mr-3 mb-3">
              <div class="hero-ring" />
              <img
                id="avatar"
                transition:name="avatar"
                src={avatar.src}
                alt="Photo of Gil Creque in a pink TV"
                class="rounded-full w-32 h-32"
                style="border: 2px solid var(--mint-green);"
              />
            </div>
            <div class="flex flex-col min-w-0">
              <div class="flex items-baseline gap-2 flex-wrap">
                <span class="hero-greeting text-xs sm:text-sm">Hello, I'm</span>
                <h1 class="inline mb-0 text-2xl sm:text-3xl">Gil</h1>
              </div>
              <p class="hero-tagline text-xs sm:text-sm">
                Software Engineer, Cyber Security Coach, Tech Community
                Organizer
              </p>
            </div>
          </>
        ) : (
          <>
            <a href="/" class="hero-avatar-wrap mr-3 focus:outline-none">
              <div class="hero-ring hero-ring--hover" />
              <img
                id="avatar"
                transition:name="avatar"
                src={avatar.src}
                alt="Photo of Gil Creque in a pink TV"
                height="100px"
                width="100px"
                class="rounded-full"
                style="border: 2px solid var(--mint-green);"
              />
            </a>
            <h1 class="grow text-center">
              <img
                src="/img/worm.svg"
                width="24px"
                height="24px"
                class="inline"
                alt="Worm Icon"
              />{" "}
              <WiggleWrap>{pageTitle}</WiggleWrap>
            </h1>
          </>
        )
      }
    </header>

    {
      isHome && (
        <nav class="md:hidden flex flex-row justify-between px-6 py-4 w-full">
          <a
            href="/blog"
            class="home-nav-btn flex flex-col items-center gap-1 text-xs w-16"
          >
            <img
              src="/img/microblog.svg"
              width="28px"
              height="28px"
              alt="Blog Icon"
            />
            Posts
          </a>
          <a
            href="/notes"
            class="home-nav-btn flex flex-col items-center gap-1 text-xs w-16"
          >
            <img
              src="/img/plant.svg"
              width="28px"
              height="28px"
              alt="Notes Icon"
            />
            Notes
          </a>
          <a
            href="/topics"
            class="home-nav-btn flex flex-col items-center gap-1 text-xs w-16"
          >
            <img
              src="/img/worm.svg"
              width="28px"
              height="28px"
              alt="Topics Icon"
            />
            Topics
          </a>
        </nav>
      )
    }

    {
      isHome ? null : (
        <main class="px-2 w-full max-w-3xl">
          <slot />
        </main>
      )
    }

    {
      isHome ? (
        <section id="home-content">
          <div id="posts-notes-row">
            <LatestPosts />
            <LatestNotes />
          </div>
          <KnowledgeGarden />
        </section>
      ) : null
    }

    <Footer />
  </body><!-- End Document
    ––––––––––––––––––––––––––––––––––––––––––––––––––
-->
</html>
