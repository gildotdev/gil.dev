---
const { title, isHome = false, frontmatter, description } = Astro.props;
const defaultDescription = "Technologist and Developer";
import Footer from "../components/Footer.astro";
import LatestNotes from "../components/LatestNotes.astro";
import WiggleWrap from "../components/WiggleWrap.astro";
import avatar from "../assets/avatar-pink-tv.jpeg";
import { ViewTransitions } from "astro:transitions";
import LatestPosts from "../components/LatestPosts.astro";
import KnowledgeGarden from "../components/KnowledgeGarden.astro";
import "../styles/global.css";
---

<!doctype html>
<html
  lang="en"
  class="bg-no-repeat bg-cover bg-gradient-to-r from-indigo-950 to-emerald-950 text-violet-50 min-h-screen"
>
  <head>
    <!-- Basic Page Needs
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta charset="utf-8" />
    <title>Gil Creque - {title || frontmatter?.title}</title>
    <meta
      name="description"
      content={description || frontmatter?.description || defaultDescription}
    />
    <meta name="author" content="Gil Creque" />

    <!-- Google Site Verification
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta
      name="google-site-verification"
      content="baTB5HjY84P_avk0rfsFGUFu6_CqqmyNZUh13QCsLM8"
    />

    <!-- Mobile Specific Metas
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicon
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
    <link
      rel="shortcut icon"
      type="image/x-icon"
      href="/img/avatar-pink-tv.jpeg"
      sizes="16x16"
    />
    <link
      rel="icon"
      type="image/x-icon"
      href="/img/avatar-pink-tv.jpeg"
      sizes="16x16"
    />
    <link rel="apple-touch-icon-precomposed" href="/img/avatar-pink-tv.jpeg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed for gil.dev"
      href="/rss.xml"
    />
    <ViewTransitions />
  </head>
  <body class="max-w-3xl mx-auto">
    <!-- Primary Page Layout
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->

    <header
      class={`flex flex-row px-2 w-full max-w-3xl items-center gap-5${isHome ? " hero-header" : " justify-center"}`}
    >
      {
        isHome ? (
          <>
            <div class="hero-avatar-wrap">
              <div class="hero-ring" />
              <img
                id="avatar"
                transition:name="avatar"
                src={avatar.src}
                alt="Photo of Gil Creque in a pink TV"
                class="rounded-full w-16 h-16"
                style="border: 2px solid var(--mint-green);"
              />
            </div>
            <div class="flex flex-col min-w-0">
              <span class="hero-greeting">Hello, I'm</span>
              <h1 class="inline mb-1">Gil</h1>
              <p class="hero-tagline">
                Software Engineer, Cyber Security Coach, Tech Community
                Organizer
              </p>
            </div>
          </>
        ) : (
          <>
            <a href="/">
              <img
                id="avatar"
                transition:name="avatar"
                src={avatar.src}
                alt="Photo of Gil Creque in a pink TV"
                height="100px"
                width="100px"
                class="rounded-full"
              />
            </a>
            <h1 class="grow text-center">
              <img
                src="/img/worm.svg"
                width="24px"
                height="24px"
                class="inline"
                alt="Worm Icon"
              />{" "}
              <WiggleWrap>{title || frontmatter.title}</WiggleWrap>
            </h1>
          </>
        )
      }
    </header>
    <main class={`px-2 w-full max-w-3xl${isHome ? " home-main" : ""}`}>
      <slot />
      <!-- your content is injected here -->
    </main>

    {
      isHome ? (
        <section id="home-content">
          <div id="posts-notes-row">
            <LatestPosts />
            <LatestNotes />
          </div>
          <KnowledgeGarden />
        </section>
      ) : null
    }

    <Footer />
  </body><!-- End Document
    ––––––––––––––––––––––––––––––––––––––––––––––––––
-->
</html>
