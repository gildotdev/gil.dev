---
import { getCollection } from "astro:content";
import { formatPublishDate } from "../lib/utils";
import "../styles/global.css";
import WiggleWrap from "./WiggleWrap.astro";

const notes = await getCollection("notes", ({ data }) => {
  return data.draft !== true;
});

const statusEmoji: Record<string, string> = {
  seed: "🌱",
  growing: "🌿",
  evergreen: "🌳",
};
---

<style>
  li {
    list-style-type: none;
  }
</style>

<aside id="notes" class="mx-2">
  <h2>
    <img
      src="/img/plant.svg"
      width="24px"
      height="24px"
      class="inline"
      alt="Plant Icon"
    />{" "}<WiggleWrap>Latest Notes</WiggleWrap>
  </h2>
  <ul>
    {
      notes
        .sort(
          (a, b) =>
            new Date(b.data.lastmod).getTime() -
            new Date(a.data.lastmod).getTime()
        )
        .slice(0, 5)
        .map((note) => (
          <li class="mb-3">
            <a href={`/${note.data.slug || note.id}`}>
              {note.data.status ? (
                <span title={note.data.status}>{statusEmoji[note.data.status]} </span>
              ) : (
                <img
                  src="/img/worm.svg"
                  width="18px"
                  height="18px"
                  class="inline"
                  alt="Worm Icon"
                />
              )}{" "}
              {note.data.title}
            </a>
            <p class="text-sm slab mt-1 mb-0 pb-0 opacity-75">
              {formatPublishDate(note.data.date)}
            </p>
          </li>
        ))
    }
  </ul>
  <p class="mt-2">
    <a href="/notes">View all notes →</a>
  </p>
</aside>
