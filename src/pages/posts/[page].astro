---
export const prerender = false;

import { marked } from "marked";
import { getLiveCollection } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import { formatPublishDate, truncateHTML } from "../../lib/utils";
import "../../styles/global.css";
import { Masonry } from "astro-masonry";
import type { MicroblogPost } from "../../lib/micropubLoader";

const PAGE_SIZE = 12;
const pageNum = parseInt(Astro.params.page ?? "1");

const result = await getLiveCollection("posts");
const allPosts = ((result.entries ?? []) as { id: string; data: MicroblogPost }[]).sort(
  (a, b) =>
    new Date(b.data.published).getTime() -
    new Date(a.data.published).getTime(),
);

const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));

if (isNaN(pageNum) || pageNum < 1 || pageNum > totalPages) {
  return Astro.redirect("/posts/1");
}

const posts = allPosts
  .slice((pageNum - 1) * PAGE_SIZE, pageNum * PAGE_SIZE)
  .map((entry) => ({
    slug: entry.id,
    content: truncateHTML(
      marked.parse(entry.data.rawContent, { async: false }),
      entry.id,
    ),
    published: entry.data.published,
    title: entry.data.title,
  }));

const firstPage = pageNum > 1 ? "/posts/1" : null;
const prevPage = pageNum > 1 ? `/posts/${pageNum - 1}` : null;
const nextPage = pageNum < totalPages ? `/posts/${pageNum + 1}` : null;
const lastPage = pageNum < totalPages ? `/posts/${totalPages}` : null;
---
<style>
a {
  color: #f5f3ff !important;
  text-decoration: none !important;
}
a:hover {
  text-decoration: none !important;
}
</style>

<PostLayout title="Posts">
  <Masonry
    breakpointCols={{ default: 4, 1100: 3, 700: 2, 500: 1 }}
    class="gap-6"
  >
    {posts.map((post) => (
      <a href={`/posts/${post.slug}`}>
        <article id={post.slug} class="mb-6 p-6 border border-gray-900 rounded-xl shadow-2xl hover:bg-black hover:bg-opacity-50">
          {post.title && <span class="slab">{post.title}</span>}
          <Fragment set:html={post.content} />
          <time class="slab text-[12px]" datetime={post.published}>
            {formatPublishDate(post.published)}
          </time>
        </article>
      </a>
    ))}
  </Masonry>
  <section class="inline-flex rounded-md shadow-xs">
    {firstPage && <a class="px-4 py-2 text-sm font-medium" href={firstPage}>First</a>}
    {prevPage  && <a class="px-4 py-2 text-sm font-medium" href={prevPage}>Previous</a>}
    {nextPage  && <a class="px-4 py-2 text-sm font-medium" href={nextPage}>Next</a>}
    {lastPage  && <a class="px-4 py-2 text-sm font-medium" href={lastPage}>Last</a>}
  </section>
</PostLayout>
