---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import Tag from "../components/Tag.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { formatPublishDate, generateDescription } from "../lib/utils.ts";
import "../styles/global.css";
// 1. Generate a new path for every collection note
export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => ({
    params: { slug: note.data.slug || note.id },
    props: { note },
  }));
}
// 2. When it's time to render, you can get the note directly from the prop
const { note } = Astro.props;
const { Content } = await render(note);

const {
  data: { title, created, updated, tags, topics, status, images },
} = note;

const noteHtml = marked(note.body ?? "") as string;
const pageDescription = note.data.description || generateDescription(noteHtml);

const allTopics = await getCollection("topics");
const topicTitles = Object.fromEntries(
  allTopics.map((t) => [t.id, t.data.title]),
);

const statusEmoji: Record<string, string> = {
  seed: "🌱",
  growing: "🌿",
  evergreen: "🌳",
};
const statusLabel: Record<string, string> = {
  seed: "Seed — early idea, lightly developed",
  growing: "Growing — being actively developed",
  evergreen: "Evergreen — mature and stable",
};
---

<MainLayout title={title} description={pageDescription} ogImage={images?.[0] ?? undefined}>
  <article>
    <div class="mb-1">
      <time class="slab" datetime={created}>
        {formatPublishDate(created)}
      </time>
    </div>
    {
      status && (
        <div class="text-sm slab mb-2" title={statusLabel[status]}>
          {statusEmoji[status]} {status}
        </div>
      )
    }
    {
      topics && topics.length > 0 && (
        <div>
          <img
            src="/img/sticky-note.svg"
            style="width:24px;height:24px;flex-shrink:0;border-radius: 0px; margin:0px;"
            class="inline"
            alt="Topics Icon"
          />{" "}
          {topics.map((topic: string) => (
            <Tag
              tag={topicTitles[topic] ?? topic}
              href={`/topics/${topic}`}
              i={0}
            />
          ))}
        </div>
      )
    }
    <Content />
    <footer>
      {
        tags.length > 0 && (
          <p>
            <img
              src="/img/tags.svg"
              width="24px"
              height="24px"
              class="inline"
              alt="Tag Icon"
            />{" "}
            {note.data.tags.map((tag: any, i: number) => (
              <Tag tag={tag} i={i} />
            ))}
          </p>
        )
      }
    </footer>
  </article>
</MainLayout>
