---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Tag from "../../components/Tag.astro";
import { getTagPaths, tagMatchesPath } from "../../lib/tags.ts";
import "../../styles/global.css";

const notes = await getCollection("notes", ({ data }) => data.draft !== true);

const tagPaths = getTagPaths(notes.flatMap((note) => note.data.tags ?? []));
const tagsWithCounts = tagPaths.map((tag) => ({
  tag,
  count: notes.filter((note) =>
    (note.data.tags ?? []).some((noteTag) => tagMatchesPath(noteTag, tag)),
  ).length,
}));
---

<MainLayout title="Tags">
  <p>All tags used across notes, sorted alphabetically.</p>
  <div class="flex flex-wrap gap-1">
    {
      tagsWithCounts.map(({ tag, count }) => (
        <Tag tag={tag} count={count} />
      ))
    }
  </div>
</MainLayout>
