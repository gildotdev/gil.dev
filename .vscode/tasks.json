{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "New note",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "new:note",
        "--",
        "${input:noteTitle}"
      ],
      "options": {
        "env": {
          "VSCODE_CLI": "1"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "dev",
      "type": "npm",
      "script": "dev",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "plugin: dev",
      "type": "npm",
      "script": "dev",
      "path": "obsidian-plugin/",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "plugin: build",
      "type": "npm",
      "script": "build",
      "path": "obsidian-plugin/",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "plugin: install",
      "type": "npm",
      "script": "install-plugin",
      "path": "obsidian-plugin/",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "noteTitle",
      "type": "promptString",
      "description": "Note title"
    }
  ]
}